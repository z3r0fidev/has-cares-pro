# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=careequity

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Auth
JWT_SECRET=careequity-dev-secret

# API Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Web Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
# Comma-separated list of allowed CORS origins (production: set to your deployed frontend URL)
CORS_ORIGIN=http://localhost:3000

# SMTP (for FR-009 insurance notifications)
# Local dev: use MailHog (docker-compose includes it at localhost:1025, UI at localhost:8025)
# Production: use Resend, Mailgun, or another SMTP relay
SMTP_HOST=localhost        # docker-compose: mailhog | production: smtp.resend.com
SMTP_PORT=1025             # docker-compose: 1025    | production: 587
SMTP_USER=dev@careequity.local        # production: your SMTP username / API key
SMTP_PASSWORD=unused                   # production: your SMTP password / API key
SMTP_FROM="CareEquity <notifications@careequity.com>"

# DB Connection Pool
DB_POOL_MAX=20
DB_POOL_MIN=2

# Twilio SMS (opt-in; leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15550000000

# Sentry (opt-in; leave blank to disable)
SENTRY_DSN=

# Availity Insurance Eligibility API (FR-eligibility; leave blank to use mock adapter)
AVAILITY_CLIENT_ID=
AVAILITY_CLIENT_SECRET=
AVAILITY_API_URL=https://api.availity.com

# Epic FHIR EHR Integration (leave blank to disable Epic slot sync)
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=
EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4

# Athenahealth EHR Integration (leave blank to disable Athena slot sync)
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=
ATHENA_API_URL=https://api.athenahealth.com/v1
