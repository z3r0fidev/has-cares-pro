{
  "name": "careequity-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "clean:all": "powershell -Command \"Get-ChildItem -Path . -Include node_modules, package-lock.json -Recurse | Remove-Item -Recurse -Force\"",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "jest",
    "build": "tsc -b",
    "start:dev": "npm run start:dev --workspace=apps/api",
    "db:migrate": "npm run migration:run --workspace=packages/db",
    "search:init": "node packages/cli/dist/index.js search init",
    "ingest": "node packages/cli/dist/index.js ingest"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "eslint": "^9.16.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "globals": "^15.13.0",
    "@eslint/js": "^9.16.0",
    "typescript-eslint": "^8.17.0",
    "@eslint/compat": "^1.2.4",
    "@radix-ui/react-slot": "^1.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6"
  },
  "overrides": {
    "glob": "^13.0.3",
    "rimraf": "^6.1.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "eslint": "^9.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@careequity/mobile": {
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "@types/react": "^18.3.12",
      "@types/react-dom": "^18.3.1"
    },
    "@babel/plugin-proposal-class-properties": "npm:@babel/plugin-transform-class-properties@^7.25.9",
    "@babel/plugin-proposal-nullish-coalescing-operator": "npm:@babel/plugin-transform-nullish-coalescing-operator@^7.25.9",
    "@babel/plugin-proposal-optional-chaining": "npm:@babel/plugin-transform-optional-chaining@^7.25.9"
  }
}
