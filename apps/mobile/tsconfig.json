{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-native",
    "lib": ["esnext"],
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "isolatedModules": true,
    "composite": true
  },
  "include": ["src/**/*", "App.tsx"],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js"
  ],
  "references": [
    { "path": "../../packages/core" }
  ]
}
