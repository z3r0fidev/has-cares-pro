# Staging environment — copy to .env.staging and fill in values

# Database
POSTGRES_HOST=staging_postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=careequity_staging

# Elasticsearch
ELASTICSEARCH_NODE=http://staging_elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Auth
JWT_SECRET=replace-with-a-secure-random-secret

# API Server
PORT=3001
NODE_ENV=staging
LOG_LEVEL=info

# Web Frontend
NEXT_PUBLIC_API_URL=http://localhost:3011

# SMTP (for FR-009 insurance notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@careequity.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="CareEquity <notifications@careequity.com>"

# DB Connection Pool
DB_POOL_MAX=20
DB_POOL_MIN=2

# Sentry (opt-in; leave blank to disable)
SENTRY_DSN=

# SSH / remote deploy coordinates (used by deploy-staging.yml)
DEPLOY_HOST=staging.example.com
DEPLOY_USER=deploy
DEPLOY_PATH=/opt/careequity-staging
